// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  USER
  ADMIN
}

model User {
  id        Int      @id @default(autoincrement()) // Felt til primær nøgle
  firstname String // Felt til tekst
  lastname  String
  email     String   @unique // Felt til tekst med unik værdi
  password  String
  role      Role
  isActive  Boolean  @default(false) // Felt til boolean (true/false)
  createdAt DateTime @default(now()) // Felt til datotid
  updatedAt DateTime @updatedAt

  @@map("users") // Navn på tabel
}

model Car {
  id         Int      @id @default(autoincrement()) // Felt til primær nøgle
  title      String // Felt til tekst model
  year       Int // Felt til tekst
  categoryId Int
  brandId    Int // Fremmednøgle - referer til brand
  price      Decimal // Felt til decimaltal
  isActive   Boolean  @default(false) // Felt til boolean (true/false)
  createdAt  DateTime @default(now())

  // Relation til category
  category Category @relation(fields: [categoryId], references: [id])

  // Relation til brand én til mange
  brand Brand @relation(fields: [brandId], references: [id])

  featureRel CarFeatureRel[]
  feature    Feature?        @relation(fields: [featureId], references: [id])
  featureId  Int?

  @@map("car") // Navn på tabel
}

model Category {
  id   Int    @id @default(autoincrement()) // Felt til primær nøgle
  name String // Felt til tekst

  // mange til én relation
  cars Car[]

  @@map("categories") // Navn på tabel
}

model Brand {
  id      Int     @id @default(autoincrement()) // Felt til primær nøgle
  name    String
  logoUrl String?

  // mange til relation
  cars Car[]

  @@map("brands") // Navn på tabel
}

model Feature {
  id   Int    @id @default(autoincrement()) // Felt til primær nøgle
  name String

  // mange til relation
  carFeatureRels CarFeatureRel[]
  cars           Car[]

  @@map("features") // Navn på tabel
}

model CarFeatureRel {
  id        Int @id @default(autoincrement()) // Felt til primær nøgle
  carId     Int
  featureId Int

  // mange til relation
  cars    Car     @relation(fields: [carId], references: [id])
  feature Feature @relation(fields: [featureId], references: [id])

  @@map("car_feature_rel") // Navn på tabel
}
