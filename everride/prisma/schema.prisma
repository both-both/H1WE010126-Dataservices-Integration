// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id Int @id @default(autoincrement()) // Felt til primær nøgle
  firstname String // Felt til tekst
  lastname String
  phone Int // Felt til heltal (Integer)
  email String @unique // Felt til tekst med unik værdi
  password String
  height Float @default(0.00) // Felt til decimaltal
  isActive Boolean @default(false) // Felt til boolean (true/false)
  createdAt DateTime @default(now()) // Felt til datotid
  updatedAt DateTime @updatedAt

  @@map("users") // Navn på tabel
}

model car {
  id Int @id @default(autoincrement()) // Felt til primær nøgle
  category String // Felt til tekst
  brand String // Felt til tekst
  model String // Felt til tekst
  year Decimal // Felt til tekst
  price Float @default(0.00) // Felt til decimaltal
  fueltype String
  hasTowBar Boolean @default(false) // Felt til boolean (true/false)
  isActive  Boolean @default(false) // Felt til boolean (true/false)
  createAt DateTime @default(now())

  @@map("cars") // Navn på tabel
}

model Category { 
  id Int @id @default(autoincrement()) // Felt til primær nøgle
  name String // Felt til tekst

  @@map("categories") // Navn på tabel
}

model Brand { 
id Int @id @default(autoincrement()) // Felt til primær nøgle
name String
logo String

@@map("brands") // Navn på tabel
}