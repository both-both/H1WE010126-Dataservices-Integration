// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}
enum Role{
  USER
  ADMIN
}

model User {
  id Int @id @default(autoincrement()) // Felt til primær nøgle
  firstname String // Felt til tekst
  lastname String
  email String @unique // Felt til tekst med unik værdi
  password String
  role Role
  isActive Boolean @default(false) // Felt til boolean (true/false)
  createdAt DateTime @default(now()) // Felt til datotid
  updatedAt DateTime @updatedAt

  @@map("users") // Navn på tabel
}

model Car {
  id Int @id @default(autoincrement()) // Felt til primær nøgle
  brandId Int // Fremmednøgle - referer til brand
  categoryId Int
  model String // Felt til tekst
  year Int // Felt til tekst
  price Float @default(0.00) // Felt til decimaltal
  fueltype String
  hasTowBar Boolean @default(false) // Felt til boolean (true/false)
  isActive  Boolean @default(false) // Felt til boolean (true/false)
  createAt DateTime @default(now())

// Relation til brand
  brand Brand @relation(fields: [brandId], references: [id]) 
  // Relation til category
  category Category @relation(fields: [categoryId], references: [id])

  @@map("car") // Navn på tabel
}

model Category { 
  id Int @id @default(autoincrement()) // Felt til primær nøgle
  name String // Felt til tekst

// Modsat relation
  cars  Car[]
  @@map("categories") // Navn på tabel
}

model Brand { 
id Int @id @default(autoincrement()) // Felt til primær nøgle
name String
logo String

  // Modsat relation
  cars  Car[]

@@map("brands") // Navn på tabel
}